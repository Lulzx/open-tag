# ─── Platforms (set at least one; the bot runs every one with a token) ───────
# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Discord bot token from the Developer Portal (Bot → Token).
# Enable the privileged "Message Content Intent" for the bot to read messages.
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Where the bot reaches the Flue agent server.
# Default matches `flue dev` (port 3583). Use http://127.0.0.1:3000 for a built server.
# FLUE_BASE_URL=http://127.0.0.1:3583

# ─── Model (pick ONE provider; the model string selects it) ──────────────────
# Change this ONE string to swap models. The prefix selects the provider wired
# in src/app.ts. Default: Ollama Cloud.
#   ollama/gpt-oss:120b            (default)
#   ollama/qwen3-coder:480b
#   ollama/deepseek-v3.1:671b
#   anthropic/claude-sonnet-4-6    (needs AI_GATEWAY_API_KEY)
#   openai/gpt-5.5                 (needs AI_GATEWAY_API_KEY)
# OPEN_TAG_MODEL=ollama/gpt-oss:120b

# Ollama Cloud API key — required for ollama/* models.
# Create one at: https://ollama.com/settings/keys
# Browse cloud models: https://ollama.com/search?c=cloud
OLLAMA_API_KEY=your_ollama_api_key_here
# OLLAMA_BASE_URL=https://ollama.com/v1

# ─── Vercel AI Gateway (optional — for anthropic/* and openai/* models) ───────
# One key, every provider, with routing + fallback.
# Get one at: https://vercel.com/[team]/~/ai-gateway/api-keys
# AI_GATEWAY_API_KEY=your_ai_gateway_api_key_here
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# ─── State ───────────────────────────────────────────────────────────────────
# File-backed SQLite path for durable per-channel sessions (Flue server).
# OPEN_TAG_DB_PATH=./data/flue.db
# Persisted self-scheduled tasks (Flue server) and the bot's channel mirror state.
# OPEN_TAG_SCHEDULE_PATH=./data/schedules.json
# OPEN_TAG_CHANNELS_PATH=./data/channels.json
