# ─── Platforms (set at least one; the bot runs every one with a token) ───────
# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Discord bot token from the Developer Portal (Bot → Token).
# Enable the privileged "Message Content Intent" for the bot to read messages.
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Where the bot reaches the Flue agent server.
# Default matches `flue dev` (port 3583). Use http://127.0.0.1:3000 for a built server.
# FLUE_BASE_URL=http://127.0.0.1:3583

# ─── Model (pick ONE provider; the model string selects it) ──────────────────
# Change this ONE string to swap models. The prefix selects the provider wired
# in src/app.ts. Default: Ollama Cloud.
#   ollama/gpt-oss:120b            (default)
#   ollama/qwen3-coder:480b
#   ollama/deepseek-v3.1:671b
#   anthropic/claude-sonnet-4-6    (needs AI_GATEWAY_API_KEY)
#   openai/gpt-5.5                 (needs AI_GATEWAY_API_KEY)
# OPEN_TAG_MODEL=ollama/gpt-oss:120b

# Ollama Cloud API key — required for ollama/* models.
# Create one at: https://ollama.com/settings/keys
# Browse cloud models: https://ollama.com/search?c=cloud
OLLAMA_API_KEY=your_ollama_api_key_here
# OLLAMA_BASE_URL=https://ollama.com/v1

# ─── Vercel AI Gateway (optional — for anthropic/* and openai/* models) ───────
# One key, every provider, with routing + fallback.
# Get one at: https://vercel.com/[team]/~/ai-gateway/api-keys
# AI_GATEWAY_API_KEY=your_ai_gateway_api_key_here
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# ─── State ───────────────────────────────────────────────────────────────────
# File-backed SQLite path for durable per-channel sessions (Flue server).
# OPEN_TAG_DB_PATH=./data/flue.db
# Persisted self-scheduled tasks (Flue server) and the bot's channel mirror state.
# OPEN_TAG_SCHEDULE_PATH=./data/schedules.json
# OPEN_TAG_CHANNELS_PATH=./data/channels.json
# Per-channel durable facts (Flue server) and ambient/config flags (bot).
# OPEN_TAG_MEMORY_PATH=./data/memory.json
# OPEN_TAG_CONFIG_PATH=./data/channel-config.json
# Per-channel policy — model override + tool RBAC (bot writes, server reads).
# OPEN_TAG_POLICY_PATH=./data/channel-policy.json

# ─── Admin (roadmap step 5) ──────────────────────────────────────────────────
# Comma-separated platform:userId allowed to change channel settings via chat
# commands (model, tools, ambient). Unset = everyone may (trusted single-tenant).
# OPEN_TAG_ADMINS=telegram:12345678,discord:9876543210

# ─── Postgres + pgvector semantic recall (optional) ──────────────────────────
# Set DATABASE_URL to (a) move Flue session storage to Postgres and (b) enable
# pgvector semantic recall (the recall_context tool). Spin one up: `docker compose up -d`.
# DATABASE_URL=postgres://opentag:opentag@localhost:5432/opentag

# Embeddings for recall — any OpenAI-compatible /embeddings endpoint. Defaults
# below fall back to your AI Gateway / Ollama base + key. Pick a model your
# endpoint serves and set the matching vector dimension.
#   OpenAI via gateway: text-embedding-3-small (dim 1536)
#   Ollama Cloud:       embeddinggemma / nomic-embed-text (dim 768)
# OPEN_TAG_EMBED_MODEL=text-embedding-3-small
# OPEN_TAG_EMBED_DIM=1536
# OPEN_TAG_EMBED_BASE_URL=https://ai-gateway.vercel.sh/v1
# OPEN_TAG_EMBED_API_KEY=your_embeddings_api_key_here

# ─── MCP connectors (optional) ───────────────────────────────────────────────
# JSON array of MCP servers surfaced as tools. They are DENIED per channel by
# default; an admin opts a channel in with `@bot mcp allow <server>`.
# OPEN_TAG_MCP_SERVERS=[{"name":"github","url":"https://mcp.example/github","transport":"streamable-http"}]
