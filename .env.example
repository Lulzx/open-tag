# Vercel AI Gateway API key — required to run the agent.
# Get one at: https://vercel.com/[team]/~/ai-gateway/api-keys
AI_GATEWAY_API_KEY=your_ai_gateway_api_key_here

# AI Gateway base URL (OpenAI-compatible endpoint).
# Default: https://ai-gateway.vercel.sh/v1
# Override to point at a different gateway (e.g. OpenRouter, local proxy).
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Model to use — provider/model string accepted by the gateway.
# Change this ONE string to swap the underlying model:
#   anthropic/claude-sonnet-4-6   (default)
#   anthropic/claude-opus-4-7
#   openai/gpt-4o
#   openai/gpt-5.5
#   google/gemini-2.0-flash
# OPEN_TAG_MODEL=anthropic/claude-sonnet-4-6
