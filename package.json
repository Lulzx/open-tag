{
  "name": "open-tag",
  "version": "0.0.1",
  "description": "Open-source model-agnostic team chat AI teammate",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "flue dev",
    "dev:bot": "node --watch --env-file-if-exists=.env src/bot/index.ts",
    "build": "flue build",
    "bot": "node --env-file-if-exists=.env src/bot/index.ts",
    "agent:hello": "flue run hello-world --input '{\"message\":\"Hello, who are you?\"}'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@flue/postgres": "1.0.0-beta.3",
    "@flue/runtime": "1.0.0-beta.5",
    "@flue/sdk": "1.0.0-beta.5",
    "discord.js": "^14.26.4",
    "grammy": "^1.44.0",
    "hono": "^4.12.27",
    "pg": "^8.22.0",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.5",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.3"
  }
}
